---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";

interface Props {
  title?: string;
}

const { title = "iago" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <div id="bg" class="page-shell">
      <div class="page">
        <SiteHeader />
        <main>
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
